# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and never committed.

# ── Google Sheets (intake form + newsletter signup) ──────────────────────────
# Both /api/intake and /api/newsletter use these credentials.
# Service account must have Editor access to the spreadsheet.
GOOGLE_SHEETS_SPREADSHEET_ID=

# The service account email (ends in @...iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# PEM private key — paste the full key including -----BEGIN / END----- lines.
# Use \n for newlines if your env provider requires a single-line value.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Tab name for intake submissions (optional, defaults to "Sheet1")
GOOGLE_SHEETS_TAB_NAME=Sheet1

# ── Stripe (enrollment payments) ─────────────────────────────────────────────
# Leave blank to run in mock mode: enrollments are saved to Sheets as "test_paid"
# with no real payment collected. Add test keys to enable Stripe Checkout.
# Get from dashboard.stripe.com → Developers → API keys

# Secret key (server-side only — never expose to the browser)
STRIPE_SECRET_KEY=

# Publishable key (safe to expose; set on NEXT_PUBLIC_ so the client can read it)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — get from Stripe dashboard → Webhooks → your endpoint
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally
STRIPE_WEBHOOK_SECRET=

# ── Supabase (accounts + dashboard) ──────────────────────────────────────────
# Get from Supabase dashboard → Project Settings → API
# NEXT_PUBLIC_ vars are safe to expose; SUPABASE_SERVICE_ROLE_KEY is server-only — never prefix with NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — bypasses RLS. Server-side only. Never commit or log this value.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL — used for auth redirect links (invite, magic link, password reset)
# In local dev: http://localhost:3000   In production: https://tennisbootcamp.ca
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Resend (transactional email) ─────────────────────────────────────────────
# Get from resend.com → API Keys
# When absent, activation links are printed to the server console instead.
RESEND_API_KEY=

# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Get from analytics.google.com → Admin → Data Streams → Web stream → Measurement ID
# Format: G-XXXXXXXXXX
# Leave blank in local dev to suppress tracking.
NEXT_PUBLIC_GA_ID=
